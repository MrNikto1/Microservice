@page "/products"
@inject HttpClient Http
@inject UserState UserState

<h3>Products</h3>

@if (products == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Name</th>
                <th>Price</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var product in products)
            {
                <tr>
                    <td>@product.Id</td>
                    <td>@product.Name</td>
                    <td>@product.Price</td>
                    <td>
                        @if (UserState.IsAuthenticated)
                        {
                            <button class="btn btn-primary btn-sm" @onclick="() => AddToCart(product)">Add to Cart</button>
                        }
                        else
                        {
                            <span class="text-muted">Login to add to cart</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@if (!string.IsNullOrEmpty(message))
{
    <div class="alert alert-info">@message</div>
}

@code {
    private Product[]? products;
    private string? message;

    protected override async Task OnInitializedAsync()
    {
        products = await Http.GetFromJsonAsync<Product[]>("api/product");
    }

    private async Task AddToCart(Product product)
    {
        if (!UserState.IsAuthenticated)
        {
            message = "Please login to add items to cart";
            return;
        }

        var cartItem = new { productId = product.Id, productName = product.Name, quantity = 1, price = product.Price };
        var response = await Http.PostAsJsonAsync($"api/cart/{UserState.CurrentUserId}/items", cartItem);
        if (response.IsSuccessStatusCode)
        {
            message = $"{product.Name} added to cart!";
        }
        else
        {
            message = "Failed to add item to cart";
        }
    }

    public class Product
    {
        public int Id { get; set; }
        public string? Name { get; set; }
        public decimal Price { get; set; }
    }
}